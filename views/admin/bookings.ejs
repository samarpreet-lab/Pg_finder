<%- include('../partials/header') %>

<%- include('../partials/adminSidebar', { activePage: 'bookings' }) %>

<main class="luxury-main">
  <header class="position-sticky top-0 luxury-header px-4 px-xl-5 py-4">
    <h1 class="font-serif fs-2 fw-bold text-primary-luxury mb-0">Manage Bookings</h1>
  </header>

  <div class="px-4 px-xl-5 py-5">
    <% if (bookings.length === 0) { %>
      <div class="alert alert-info bg-opacity-10 border border-info text-info">
        <i class="bi bi-info-circle"></i> No bookings yet.
      </div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-borderless w-100 mb-0 admin-table-spaced">
        <thead>
          <tr>
            <th class="admin-table-header">Guest Identity</th>
            <th class="admin-table-header">Accommodation</th>
            <th class="admin-table-header">Timeline</th>
            <th class="admin-table-header text-end">Financials</th>
            <th class="admin-table-header text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(b => { %>
          <tr class="luxury-card-static">
            <td class="admin-table-cell">
              <div class="font-serif fw-bold text-primary-luxury mb-1"><%= b.guestName %></div>
              <small class="text-muted-luxury"><i class="bi bi-hash icon-sm"></i> <%= b._id.toString().slice(-8) %></small>
            </td>
            <td class="admin-table-cell">
              <div class="font-serif fw-bold text-primary-luxury mb-2"><%= b.room?.name || 'Deleted Room' %></div>
              <% if (b.status === 'Confirmed') { %>
                <span class="badge badge-confirmed">
                  <i class="bi bi-check-circle-fill icon-sm"></i> Confirmed
                </span>
              <% } else if (b.status === 'Cancelled') { %>
                <span class="badge badge-cancelled">
                  <i class="bi bi-x-circle-fill icon-sm"></i> Cancelled
                </span>
              <% } else { %>
                <span class="badge badge-pending">
                  <i class="bi bi-clock-fill icon-sm"></i> Pending
                </span>
              <% } %>
            </td>
            <td class="admin-table-cell">
              <small class="text-muted-luxury"><%= new Date(b.checkIn).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %> – <%= b.checkOut ? new Date(b.checkOut).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : 'Not set' %></small>
            </td>
            <td class="admin-table-cell text-end">
              <div class="fw-bold text-primary-luxury price-display mb-1">₹<%= b.totalPrice.toLocaleString() %></div>
              <small class="text-muted-luxury">@ ₹<%= b.monthlyRate %>/month</small>
            </td>
            <td class="admin-table-cell text-end">
              <form action="/admin/bookings/<%= b._id %>/update" method="POST" class="d-inline">
                <select name="status" class="form-select form-select-sm form-select-luxury d-inline-block w-auto"
                        onchange="this.form.submit()">
                  <option value="Pending" <%= b.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                  <option value="Confirmed" <%= b.status === 'Confirmed' ? 'selected' : '' %>>Confirmed</option>
                  <option value="Cancelled" <%= b.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                </select>
              </form>
              <a href="/admin/bookings/<%= b._id %>/details" class="btn btn-luxury-primary btn-sm ms-2">
                <i class="bi bi-eye"></i> View
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</main>

<%- include('../partials/footer') %>

