<%- include('../partials/header') %>

<!-- Custom Sidebar -->
<aside class="position-fixed top-0 start-0 h-100 luxury-sidebar d-flex flex-column p-4 p-xl-5">
  <div class="mb-4">
    <span class="font-serif fs-3 fw-bold d-block text-primary-luxury mb-1">StayEase</span>
    <span class="text-muted-luxury text-uppercase fw-bold subheading-light">Affordable Living</span>
  </div>
  
  <nav class="flex-grow-1 d-flex flex-column gap-3 mt-4">
    <a href="/admin" class="nav-link-luxury active">
      <i class="bi bi-speedometer2"></i> Dashboard
    </a>
    <a href="/admin/rooms" class="nav-link-luxury">
      <i class="bi bi-building"></i> Properties
    </a>
    <a href="/admin/bookings" class="nav-link-luxury">
      <i class="bi bi-calendar2-check"></i> Reservations
    </a>
  </nav>

  <div class="mt-auto pt-4 border-top border-dark border-opacity-10 d-flex flex-column gap-3">
    <a href="/" class="nav-link-luxury">
      <i class="bi bi-box-arrow-right"></i> Sign Out
    </a>
  </div>
</aside>

<!-- Main Content -->
<main class="luxury-main">
  <!-- Header -->
  <header class="position-sticky top-0 luxury-header px-4 px-xl-5 py-4 d-flex justify-content-between align-items-center">
    <div>
      <h1 class="font-serif fs-2 fw-bold text-primary-luxury mb-1">Dashboard Overview</h1>
      <p class="text-muted-luxury text-uppercase mb-0 subheading-light">
        <%= new Date().toDateString() %>
      </p>
    </div>
    <div class="d-flex align-items-center gap-4">
      <div class="text-end d-none d-md-block">
        <span class="d-block fw-bold text-uppercase text-primary-luxury admin-panel-label">Admin Panel</span>
        <span class="d-block text-muted-luxury text-uppercase admin-panel-label">Administrator</span>
      </div>
      <a href="/admin/rooms/new" class="btn btn-luxury-primary text-decoration-none">Create Booking</a>
    </div>
  </header>

  <div class="px-4 px-xl-5 py-5">
    <!-- Top KPIs -->
    <div class="row g-5 mb-5 pb-4">
      <div class="col-md-4">
        <div class="stat-label">Total Rooms</div>
        <div class="d-flex align-items-end gap-2">
          <span class="font-serif text-primary-luxury stat-value"><%= totalRooms %></span>
          <i class="bi bi-graph-up-arrow text-secondary-luxury fs-5 mb-2"></i>
        </div>
        <div class="stat-divider"></div>
        <p class="text-muted-luxury mb-0 text-small-muted">Updated property count</p>
      </div>

      <div class="col-md-4">
        <div class="stat-label">Total Bookings</div>
        <div class="d-flex align-items-end gap-2">
          <span class="font-serif text-primary-luxury stat-value"><%= totalBookings %></span>
          <i class="bi bi-check-circle-fill text-secondary-luxury fs-5 mb-2"></i>
        </div>
        <div class="stat-divider"></div>
        <p class="text-muted-luxury mb-0 text-small-muted">All time aggregate views</p>
      </div>

      <div class="col-md-4">
        <div class="stat-label">Revenue</div>
        <div class="d-flex align-items-end gap-2">
          <span class="font-serif text-primary-luxury stat-value fw-bold">₹<%= typeof revenue !== 'undefined' ? revenue : 0 %></span>
        </div>
        <div class="stat-divider"></div>
        <p class="text-muted-luxury mb-0 text-small-muted">Lifetime system revenue</p>
      </div>
    </div>

    <!-- Recent Bookings Table -->
    <div class="mb-5">
      <div class="d-flex justify-content-between align-items-baseline mb-4">
        <h2 class="font-serif fs-3 fw-bold text-primary-luxury">Recent Bookings</h2>
        <a href="/admin/bookings" class="text-muted-luxury text-uppercase text-decoration-none border-bottom border-dark pb-1 subheading-light">View all archives</a>
      </div>

      <div class="table-responsive">
        <table class="table table-borderless table-luxury w-100 mb-0">
          <thead>
            <tr>
              <th>Guest Name</th>
              <th>Room Category</th>
              <th>Check In</th>
              <th>Check Out</th>
              <th class="text-end">Status</th>
            </tr>
          </thead>
          <tbody>
            <% recentBookings.forEach(b => { %>
            <tr class="align-middle">
              <td>
                <div class="font-serif fs-5 fw-bold text-primary-luxury"><%= b.guestName %></div>
                <div class="text-muted-luxury text-uppercase mt-1 subheading-light">Guest</div>
              </td>
              <td class="text-muted-luxury"><%= b.room?.type || 'N/A' %> - <%= b.room?.name || 'N/A' %></td>
              <td class="text-muted-luxury"><%= new Date(b.checkIn).toLocaleDateString() %></td>
              <td class="text-muted-luxury"><%= new Date(b.checkOut).toLocaleDateString() %></td>
              <td class="text-end">
                <% if (b.status === 'Confirmed') { %>
                  <span class="badge-luxury badge-confirmed d-inline-block"><%= b.status %></span>
                <% } else if (b.status === 'Cancelled') { %>
                  <span class="badge-luxury badge-cancelled d-inline-block"><%= b.status %></span>
                <% } else { %>
                  <span class="badge-luxury badge-pending d-inline-block"><%= b.status %></span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    
  </div>

</main>

<%- include('../partials/footer') %>
