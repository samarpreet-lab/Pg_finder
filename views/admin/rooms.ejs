<%- include('../partials/header') %>

<style>
nav.navbar { display: none !important; }
footer.bg-dark { display: none !important; }
body { padding-bottom: 0 !important; }

@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Noto+Serif:ital,wght@0,400;0,700;1,400&display=swap');

:root {
  --bg-luxury: #fcf9f4;
  --text-primary: #171817;
  --text-secondary: #715a3e;
  --text-muted: #8c8c88;
  --border-color: rgba(23, 24, 23, 0.1);
}

body {
  background-color: var(--bg-luxury) !important;
  color: var(--text-primary);
  font-family: 'Manrope', sans-serif;
}

.font-serif { font-family: 'Noto Serif', serif; }
.text-primary-luxury { color: var(--text-primary); }
.text-secondary-luxury { color: var(--text-secondary); }
.text-muted-luxury { color: var(--text-muted); }

.luxury-sidebar {
  width: 280px;
  background-color: var(--bg-luxury);
  border-right: 1px solid var(--border-color);
}

.luxury-main { margin-left: 280px; min-height: 100vh; }
.luxury-header { background: rgba(252, 249, 244, 0.8); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border-color); z-index: 1030; }

.nav-link-luxury {
  color: var(--text-muted);
  font-weight: 700;
  font-size: 0.75rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  transition: color 0.3s;
  text-decoration: none;
  display: flex;
  align-items: center;
  padding: 0.5rem 1rem;
}

.nav-link-luxury:hover { color: var(--text-secondary); }
.nav-link-luxury.active { border-left: 2px solid var(--text-primary); color: var(--text-primary); margin-left: -2px; }
.nav-link-luxury i { font-size: 1.2rem; margin-right: 1rem; }

.btn-luxury-primary {
  background-color: var(--text-primary);
  color: #fff;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  padding: 0.75rem 1.5rem;
  border-radius: 0;
  transition: opacity 0.3s;
}
.btn-luxury-primary:hover { opacity: 0.9; color: #fff; }

.table-luxury {
  border-collapse: separate;
  border-spacing: 0 0.9rem;
  width: 100%;
}
.table-luxury thead th {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--text-muted);
  border-bottom: 1px solid var(--border-color);
  padding: 1rem 1.5rem 0.75rem;
  background: transparent;
}
.table-luxury tbody tr {
  background: #fff;
  box-shadow: 0 0 0 1px rgba(23, 24, 23, 0.06);
}
.table-luxury td {
  padding: 1.25rem 1.5rem;
  border: none;
  vertical-align: middle;
}
.table-luxury td:first-child,
.table-luxury th:first-child {
  padding-left: 2rem;
}
.table-luxury td:last-child,
.table-luxury th:last-child {
  padding-right: 2rem;
}
.badge-luxury { font-size: 0.55rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.35rem 0.75rem; font-weight: 700; }
.admin-footer { margin-left: 280px; width: calc(100% - 280px); }
</style>

<aside class="position-fixed top-0 start-0 h-100 luxury-sidebar d-flex flex-column p-4 p-xl-5">
  <div class="mb-4">
    <span class="font-serif fs-3 fw-bold d-block text-primary-luxury mb-1">StayEase</span>
    <span class="text-muted-luxury text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.05em;">Affordable Living</span>
  </div>
  
  <nav class="flex-grow-1 d-flex flex-column gap-3 mt-4">
    <a href="/admin" class="nav-link-luxury">
      <i class="bi bi-speedometer2"></i> Dashboard
    </a>
    <a href="/admin/rooms" class="nav-link-luxury active">
      <i class="bi bi-building"></i> Properties
    </a>
    <a href="/admin/bookings" class="nav-link-luxury">
      <i class="bi bi-calendar2-check"></i> Reservations
    </a>
  </nav>

  <div class="mt-auto pt-4 border-top border-dark border-opacity-10 d-flex flex-column gap-3">
    <a href="/" class="nav-link-luxury">
      <i class="bi bi-box-arrow-right"></i> Sign Out
    </a>
  </div>
</aside>

<main class="luxury-main">
  <header class="position-sticky top-0 luxury-header px-4 px-xl-5 py-4 d-flex justify-content-between align-items-center">
    <h1 class="font-serif fs-2 fw-bold text-primary-luxury mb-0">Manage Rooms</h1>
    <a href="/admin/rooms/new" class="btn btn-luxury-primary text-decoration-none">
      <i class="bi bi-plus-circle"></i> Add New Room
    </a>
  </header>

  <div class="px-4 px-xl-5 py-5">
    <% if (rooms.length === 0) { %>
      <div class="alert alert-info bg-opacity-10 border border-info text-info">
        <i class="bi bi-info-circle"></i> No rooms found. Add your first room!
      </div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-borderless w-100 mb-0" style="border-collapse: separate; border-spacing: 0 1rem;">
        <thead>
          <tr>
            <th style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: #8c8c88; font-weight: 700; padding-bottom: 1rem; border-bottom: 1px solid #e0dbd6;">Pg Details</th>
            <th style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: #8c8c88; font-weight: 700; padding-bottom: 1rem; border-bottom: 1px solid #e0dbd6;">Room Type</th>
            <th style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: #8c8c88; font-weight: 700; padding-bottom: 1rem; border-bottom: 1px solid #e0dbd6;">Pricing</th>
            <th style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: #8c8c88; font-weight: 700; padding-bottom: 1rem; border-bottom: 1px solid #e0dbd6; text-align: right;">Availability</th>
            <th style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: #8c8c88; font-weight: 700; padding-bottom: 1rem; border-bottom: 1px solid #e0dbd6; text-align: right;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% rooms.forEach(room => { %>
          <tr style="background: #fff; box-shadow: 0 0 0 1px rgba(23, 24, 23, 0.06);">
            <td style="padding: 1.5rem; vertical-align: middle; min-width: 250px;">
              <div style="display: flex; gap: 1rem; align-items: center;">
                <img src="<%= room.image %>" alt="<%= room.name %>"
                     style="width: 80px; height: 60px; object-fit: cover; border-radius: 4px;"/>
                <div>
                  <div class="font-serif fw-bold text-primary-luxury" style="margin-bottom: 0.25rem;"><%= room.name %></div>
                  <small class="text-muted-luxury"><i class="bi bi-star-fill"></i> <%= room.rating %> rating</small>
                </div>
              </div>
            </td>
            <td style="padding: 1.5rem; vertical-align: middle;">
              <span class="badge" style="background-color: #e8e0f5; color: #483d8b; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.5rem 0.75rem;">
                <%= room.type %>
              </span>
            </td>
            <td style="padding: 1.5rem; vertical-align: middle;">
              <div class="font-serif fw-bold text-primary-luxury" style="font-size: 1.1rem; margin-bottom: 0.25rem;">₹<%= room.monthlyPrice.toLocaleString() %></div>
              <small class="text-muted-luxury">/month</small>
            </td>
            <td style="padding: 1.5rem; vertical-align: middle; text-align: right;">
              <% if (room.isAvailable) { %>
                <span class="badge" style="background-color: #d7e7d5; color: #121e14; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.5rem 0.75rem;">
                  <i class="bi bi-check-circle-fill"></i> Available
                </span>
              <% } else { %>
                <span class="badge" style="background-color: #ffdad6; color: #93000a; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.5rem 0.75rem;">
                  <i class="bi bi-x-circle-fill"></i> Unavailable
                </span>
              <% } %>
            </td>
            <td style="padding: 1.5rem; vertical-align: middle; text-align: right;">
              <a href="/admin/rooms/<%= room._id %>/edit" class="btn btn-sm" style="background-color: #fcf9f4; color: #715a3e; border: 1px solid #e0dbd6; font-weight: 700; font-size: 0.75rem; padding: 0.5rem 0.75rem; margin-right: 0.5rem;" title="Edit">
                <i class="bi bi-pencil"></i> Edit
              </a>
              <form action="/admin/rooms/<%= room._id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm" style="background-color: #ffdad6; color: #93000a; border: 1px solid #f1a199; font-weight: 700; font-size: 0.75rem; padding: 0.5rem 0.75rem;"
                        onclick="return confirm('Are you sure you want to delete this room?')" title="Delete">
                  <i class="bi bi-trash"></i> Delete
                </button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</main>

<%- include('../partials/footer') %>
