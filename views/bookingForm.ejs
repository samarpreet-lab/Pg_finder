<%- include('partials/header') %>

<main class="luxury-main">
  <div class="container-fluid py-5 px-4 px-xl-5">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-10">
        <div class="row g-4">
          <div class="col-lg-5">
            <!-- Room Summary -->
            <div class="luxury-card-static mb-4">
              <div class="card-body">
                <div class="d-flex align-items-flex-start gap-4">
                  <img src="<%= room.image %>" class="room-summary-image" alt="<%= room.name %>"/>
                  <div class="flex-grow-1">
                    <h5 class="font-serif fw-bold mb-2 text-primary-luxury"><%= room.name %></h5>
                    <span class="badge badge-luxury badge-pending"><%= room.type === 'Single' ? 'Single Occupancy' : room.type === 'Double' ? 'Double Sharing' : room.type === 'Suite' ? 'Triple / Family' : 'Shared / Family' %></span>
                    <p class="mb-0 text-muted-luxury mt-3 fs-09">₹<%= room.monthlyPrice %>/month</p>
                  </div>
                </div>
              </div>
            </div>

            <% if (room.utilities) { %>
            <div class="luxury-card-static mb-4">
              <div class="card-body utilities-section">
                <h6 class="font-serif fw-bold text-primary-luxury d-flex align-items-center gap-2">
                  <i class="bi bi-lightning-charge-fill"></i> Utilities Billing
                </h6>
                <div class="utilities-item">
                  <span class="utilities-label">Electricity:</span>
                  <span class="badge badge-luxury badge-confirmed utilities-badge"><%= room.utilities.electricity %></span>
                </div>
                <div class="utilities-item">
                  <span class="utilities-label">Water:</span>
                  <span class="badge badge-luxury badge-confirmed utilities-badge"><%= room.utilities.water %></span>
                </div>
                <p class="utilities-note mb-0"><strong>Note:</strong> <%= room.utilities.description %></p>
              </div>
            </div>
            <% } %>
          </div>

          <div class="col-lg-7">
            <div class="luxury-card-static h-100">
              <div class="card-header bg-dark text-white py-3 px-4">
                <span class="font-sans fw-bold text-uppercase fs-075 letter-spacing-1">
                  <i class="bi bi-calendar-plus"></i>&nbsp; Complete Your Booking
                </span>
              </div>
              <div class="card-body p-4">
                <div class="mb-4 pb-3 border-bottom border-dark border-opacity-10">
                  <small class="text-muted-luxury"><span class="text-danger fw-bold">*</span> indicates required fields</small>
                </div>
                <form action="/book/<%= room._id %>" method="POST" enctype="multipart/form-data">
                  <div class="mb-4">
                    <label class="form-label">Full Name <span class="text-danger fw-bold">*</span></label>
                    <input type="text" name="guestName" class="form-control" placeholder="Enter your name" required/>
                  </div>

                  <div class="mb-4">
                    <label class="form-label">Email Address <span class="text-danger fw-bold">*</span></label>
                    <input type="email" name="email" class="form-control" placeholder="you@example.com" required/>
                  </div>

                  <div class="mb-4">
                    <label class="form-label">Phone Number <span class="text-danger fw-bold">*</span></label>
                    <input type="tel" name="phone" class="form-control" placeholder="10-digit mobile number" required/>
                  </div>

                  <div class="mb-4">
                    <label class="form-label">Aadhar Number <span class="text-danger fw-bold">*</span></label>
                    <input type="text" name="aadharNumber" class="form-control" placeholder="12-digit Aadhar number" pattern="[0-9]{12}" maxlength="12" required/>
                    <small class="form-text text-muted">Enter your 12-digit Aadhar number</small>
                  </div>

                  <div class="mb-4">
                    <label class="form-label">Upload Aadhar Card (PDF or JPG) <span class="text-danger fw-bold">*</span></label>
                    <input type="file" name="aadharPdf" class="form-control" accept=".pdf,.jpg,.jpeg" required/>
                    <small class="form-text text-muted">Max file size: 5MB. Supported formats: PDF, JPG, JPEG</small>
                  </div>

                  <div class="row g-3 mb-4">
                    <div class="col-md-6">
                      <label class="form-label">Move-In Date <span class="text-danger fw-bold">*</span></label>
                      <input type="date" name="checkIn" id="checkIn" class="form-control" required/>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Move-Out Date</label>
                      <input type="date" name="checkOut" id="checkOut" class="form-control"/>
                    </div>
                  </div>

                  <div class="row g-3 mb-4">
                    <div class="col-md-6">
                      <label class="form-label">Number of Guests</label>
                      <input type="number" name="guests" class="form-control" value="1" min="1" max="10"/>
                    </div>
                  </div>

                  <div class="price-preview d-none mb-4" id="pricePreview">
                    <div class="price-preview-total">
                      <strong class="price-preview-total">Monthly Rent: ₹<span id="totalAmount"><%= room.monthlyPrice %></span></strong>
                    </div>
                  </div>

                  <button type="submit" class="btn btn-luxury-primary w-100 btn-lg">
                    <i class="bi bi-check-circle"></i>&nbsp; Confirm Booking
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  const checkInInput = document.getElementById('checkIn');
  const pricePreview = document.getElementById('pricePreview');

  function showPricePreview() {
    if (checkInInput.value) {
      pricePreview.classList.remove('d-none');
    }
  }

  checkInInput.addEventListener('change', showPricePreview);
</script>

<%- include('partials/footer') %>