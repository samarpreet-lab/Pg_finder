<%- include('partials/header') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Noto+Serif:ital,wght@0,400;0,700;1,400&display=swap');

  :root {
    --bg-luxury: #fcf9f4;
    --text-primary: #171817;
    --text-secondary: #715a3e;
    --text-muted: #8c8c88;
    --border-color: rgba(23, 24, 23, 0.1);
  }

  body {
    background-color: var(--bg-luxury) !important;
    color: var(--text-primary);
    font-family: 'Manrope', sans-serif;
  }

  .luxury-main {
    margin-left: 280px;
    min-height: 100vh;
    background-color: var(--bg-luxury);
  }

  .font-serif { font-family: 'Noto Serif', serif; }
  .font-sans { font-family: 'Manrope', sans-serif; }
  .text-primary-luxury { color: var(--text-primary); }
  .text-secondary-luxury { color: var(--text-secondary); }
  .text-muted-luxury { color: var(--text-muted); }

  .btn-luxury-primary {
    background-color: var(--text-primary);
    color: white !important;
    border: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    font-size: 0.75rem;
    border-radius: 0;
    transition: opacity 0.3s;
  }

  .btn-luxury-primary:hover {
    opacity: 0.9;
    color: white !important;
  }

  .badge-luxury {
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    font-weight: 700;
    border-radius: 0;
  }

  .badge-confirmed { background-color: #d7e7d5; color: #121e14; }
  .badge-pending { background-color: #fdddb9; color: #786044; }

  .form-control {
    border: 1px solid var(--border-color);
    border-radius: 0;
    background-color: #fff;
    color: var(--text-primary);
    padding: 0.75rem 1rem;
  }

  .form-control:focus {
    border-color: var(--text-secondary);
    box-shadow: 0 0 0 0.2rem rgba(113, 90, 62, 0.1);
  }

  .form-label {
    color: var(--text-muted);
    font-weight: 700;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .luxury-card {
    background: #fff;
    box-shadow: 0 0 0 1px rgba(23, 24, 23, 0.06);
    border: none;
    border-radius: 0;
  }

  .luxury-card .card-header {
    background-color: var(--text-primary);
    border-bottom: none;
    padding: 1.25rem 1.5rem;
    color: #fff;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .luxury-card .card-body {
    padding: 2rem;
  }

  .price-preview {
    background-color: #f5f3ee;
    border: 1px solid var(--border-color);
    border-radius: 0;
    padding: 1.5rem;
    color: var(--text-primary);
  }
</style>

<main class="luxury-main">
  <div class="container-fluid py-5 px-4 px-xl-5">
    <div class="row justify-content-center">
      <div class="col-lg-6">

      <!-- Room Summary -->
      <div class="luxury-card mb-4">
        <div class="card-body d-flex align-items-center gap-3">
          <img src="<%= room.image %>" style="width:80px; height:60px; object-fit:cover; border-radius: 0;"
               alt="<%= room.name %>"/>
          <div class="flex-grow-1">
            <h5 class="font-serif fw-bold mb-1 text-primary-luxury"><%= room.name %></h5>
            <span class="badge badge-luxury badge-pending"><%= room.type === 'Single' ? 'Single Occupancy' : room.type === 'Double' ? 'Double Sharing' : room.type === 'Suite' ? 'Triple / Family' : 'Shared / Family' %></span>
            <p class="mb-0 text-muted-luxury mt-2" style="font-size: 0.9rem;">₹<%= room.monthlyPrice %>/month</p>
          </div>
        </div>
      </div>

      <% if (room.utilities) { %>
      <div class="luxury-card mb-4">
        <div class="card-body">
          <h6 class="font-serif fw-bold mb-3 text-primary-luxury"><i class="bi bi-lightning-charge-fill"></i> Utilities Billing</h6>
          <p class="mb-2" style="font-size: 0.9rem;">
            <strong class="text-primary-luxury">Electricity:</strong>
            <span class="badge badge-luxury badge-confirmed" style="margin-left: 0.5rem;"><%= room.utilities.electricity %></span>
          </p>
          <p class="mb-3" style="font-size: 0.9rem;">
            <strong class="text-primary-luxury">Water:</strong>
            <span class="badge badge-luxury badge-confirmed" style="margin-left: 0.5rem;"><%= room.utilities.water %></span>
          </p>
          <p class="text-muted-luxury small mb-0">Note: <%= room.utilities.description %></p>
        </div>
      </div>
      <% } %>

      <div class="luxury-card">
        <div class="card-header">
          <i class="bi bi-calendar-plus"></i> Complete Your Booking
        </div>
        <div class="card-body">
          <form action="/book/<%= room._id %>" method="POST">
            <div class="mb-4">
              <label class="form-label">Full Name</label>
              <input type="text" name="guestName" class="form-control" placeholder="Enter your name" required/>
            </div>

            <div class="mb-4">
              <label class="form-label">Email Address</label>
              <input type="email" name="email" class="form-control" placeholder="you@example.com" required/>
            </div>

            <div class="mb-4">
              <label class="form-label">Phone Number</label>
              <input type="tel" name="phone" class="form-control" placeholder="10-digit mobile number" required/>
            </div>

            <div class="row g-3 mb-4">
              <div class="col-md-6">
                <label class="form-label">Move-In Date</label>
                <input type="date" name="checkIn" id="checkIn" class="form-control" required/>
              </div>
              <div class="col-md-6">
                <label class="form-label">Move-Out Date</label>
                <input type="date" name="checkOut" id="checkOut" class="form-control" required/>
              </div>
            </div>

            <div class="row g-3 mb-4">
              <div class="col-md-6">
                <label class="form-label">Number of Guests</label>
                <input type="number" name="guests" class="form-control" value="1" min="1" max="10"/>
              </div>
              <div class="col-md-6">
                <label class="form-label">Duration (Months)</label>
                <input type="number" name="months" id="months" class="form-control" value="1" min="1" max="12" required/>
              </div>
            </div>

            <div class="price-preview" id="pricePreview" style="display:none; margin-bottom: 2rem;">
              <div class="mb-2" style="font-size: 0.9rem;">
                <strong>Monthly Rate:</strong> <span style="float: right;">₹<%= room.monthlyPrice %></span>
              </div>
              <div class="mb-2" style="font-size: 0.9rem;">
                <strong id="monthsDisplay">Months: 1</strong>
              </div>
              <div style="border-top: 1px solid var(--border-color); padding-top: 1rem; margin-top: 1rem;">
                <strong class="price-preview-total">Total Rent: ₹<span id="totalAmount"><%= room.monthlyPrice %></span></strong>
              </div>
            </div>

            <button type="submit" class="btn btn-luxury-primary w-100 btn-lg">
              <i class="bi bi-check-circle"></i> Confirm Booking
            </button>
          </form>
        </div>
      </div>

      </div>
    </div>
  </div>
</main>

<script>
  const pricePerMonth = <%= room.monthlyPrice %>;
  const monthsInput = document.getElementById('months');
  const pricePreview = document.getElementById('pricePreview');
  const totalAmount = document.getElementById('totalAmount');
  const monthsDisplay = document.getElementById('monthsDisplay');

  function updatePrice() {
    const months = parseInt(monthsInput.value) || 1;
    const total = pricePerMonth * months;
    totalAmount.textContent = '₹' + total;
    monthsDisplay.textContent = 'Months: ' + months;
    pricePreview.style.display = 'block';
  }

  monthsInput.addEventListener('change', updatePrice);
  monthsInput.addEventListener('input', updatePrice);
  updatePrice();
</script>

<%- include('partials/footer') %>