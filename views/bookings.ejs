<%- include('partials/header') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Noto+Serif:ital,wght@0,400;0,700;1,400&display=swap');

  :root {
    --bg-luxury: #fcf9f4;
    --text-primary: #171817;
    --text-secondary: #715a3e;
    --text-muted: #8c8c88;
    --border-color: rgba(23, 24, 23, 0.1);
  }

  body {
    background-color: var(--bg-luxury) !important;
    color: var(--text-primary);
    font-family: 'Manrope', sans-serif;
  }

  .luxury-main {
    margin-left: 280px;
    min-height: 100vh;
    background-color: var(--bg-luxury);
  }

  .font-serif { font-family: 'Noto Serif', serif; }
  .font-sans { font-family: 'Manrope', sans-serif; }
  .text-primary-luxury { color: var(--text-primary); }
  .text-secondary-luxury { color: var(--text-secondary); }
  .text-muted-luxury { color: var(--text-muted); }

  .btn-luxury-primary {
    background-color: var(--text-primary);
    color: white !important;
    border: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    font-size: 0.75rem;
    border-radius: 0;
    transition: opacity 0.3s;
  }

  .btn-luxury-primary:hover {
    opacity: 0.9;
    color: white !important;
  }

  .badge-luxury {
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    font-weight: 700;
    border-radius: 0;
  }

  .badge-confirmed { background-color: #d7e7d5; color: #121e14; }
  .badge-pending { background-color: #fdddb9; color: #786044; }

  .table-luxury {
    border-collapse: separate;
    border-spacing: 0 0.9rem;
    width: 100%;
  }
  
  .table-luxury thead th {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-color);
    padding: 1rem 1.5rem 0.75rem;
    background: transparent;
    font-weight: 700;
  }
  
  .table-luxury tbody tr {
    background: #fff;
    box-shadow: 0 0 0 1px rgba(23, 24, 23, 0.06);
  }
  
  .table-luxury td {
    padding: 1.25rem 1.5rem;
    border: none;
    vertical-align: middle;
  }
  
  .table-luxury td:first-child,
  .table-luxury th:first-child {
    padding-left: 2rem;
  }
  
  .table-luxury td:last-child,
  .table-luxury th:last-child {
    padding-right: 2rem;
  }

  .stat-card {
    background-color: #f5f3ee;
    border: 1px solid var(--border-color);
    border-radius: 0;
    padding: 2rem;
    text-align: center;
  }

  .stat-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-secondary);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .stat-value {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1;
    color: var(--text-primary);
    font-family: 'Noto Serif', serif;
  }
</style>

<main class="luxury-main">
  <div class="container-fluid py-5 px-4 px-xl-5">
    <!-- Header Section -->
    <header class="mb-5">
      <span class="text-uppercase font-sans fw-bold text-secondary-luxury" style="font-size: 0.65rem; letter-spacing: 0.2em;">Your Reservations</span>
      <h1 class="font-serif fw-bold mt-3 mb-3 text-primary-luxury" style="font-size: 2.5rem;">My Bookings</h1>
      <p class="text-muted-luxury font-sans">Track and manage all your room bookings in one place</p>
    </header>

    <!-- Bookings List -->
    <% if (bookings.length === 0) { %>
      <div class="p-5 text-center" style="background-color: #f5f3ee; border: 1px solid var(--border-color);">
        <i class="bi bi-calendar-x" style="font-size: 3rem; color: #8c8c88;"></i>
        <h3 class="font-serif mt-4" style="color: #171817;">No Bookings Yet</h3>
        <p class="font-sans mt-2" style="color: #8c8c88;">
          Browse our rooms and make your first reservation!
        </p>
        <a href="/rooms" class="btn btn-luxury-primary mt-3">
          <i class="bi bi-building"></i> Browse Rooms
        </a>
      </div>
    <% } else { %>
    <div class="row g-4 mb-5">
      <!-- Bookings Table -->
      <div class="col-12">
        <div class="table-responsive">
          <table class="table table-borderless table-luxury w-100 mb-0">
            <thead>
              <tr>
                <th>Room Name</th>
                <th>Guest Name</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Duration</th>
                <th>Status</th>
                <th class="text-end">Action</th>
              </tr>
            </thead>
            <tbody>
              <% bookings.forEach(booking => { %>
              <tr>
                <td>
                  <div class="font-serif fw-bold text-primary-luxury" style="font-size: 1rem;"><%= booking.room ? booking.room.name : 'Unknown Room' %></div>
                  <div class="text-muted-luxury mt-1" style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.05em;">Room</div>
                </td>
                <td class="text-primary-luxury font-sans"><%= booking.guestName %></td>
                <td class="text-muted-luxury font-sans"><%= new Date(booking.checkIn).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
                <td class="text-muted-luxury font-sans"><%= new Date(booking.checkOut).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
                <td class="text-muted-luxury font-sans">
                  <% const months = booking.months || 1; %>
                  <%= months %> <%= months === 1 ? 'month' : 'months' %>
                </td>
                <td>
                  <span class="badge badge-luxury badge-confirmed">
                    <i class="bi bi-check-circle-fill"></i> Confirmed
                  </span>
                </td>
                <td class="text-end">
                  <a href="/confirmation/<%= booking._id %>" class="btn btn-luxury-primary" style="padding: 0.5rem 1rem;">
                    <i class="bi bi-eye"></i> View
                  </a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Booking Stats -->
      <div class="col-12 mt-5">
        <div class="row g-4">
          <div class="col-md-4">
            <div class="stat-card">
              <div class="stat-label">Total Bookings</div>
              <div class="stat-value"><%= bookings.length %></div>
              <div style="width: 100%; height: 1px; background-color: rgba(197, 199, 194, 0.3); margin: 1rem 0;"></div>
              <p class="font-sans mb-0" style="font-size: 0.75rem; color: #8c8c88;">All time reservations</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="stat-card">
              <div class="stat-label">Active Bookings</div>
              <div class="stat-value"><%= bookings.filter(b => new Date(b.checkOut) > new Date()).length %></div>
              <div style="width: 100%; height: 1px; background-color: rgba(197, 199, 194, 0.3); margin: 1rem 0;"></div>
              <p class="font-sans mb-0" style="font-size: 0.75rem; color: #8c8c88;">Currently active stays</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="stat-card">
              <div class="stat-label">Total Spent</div>
              <div class="stat-value">₹<%= bookings.reduce((sum, b) => sum + (b.room ? b.room.monthlyPrice * (b.months || 1) : 0), 0) %></div>
              <div style="width: 100%; height: 1px; background-color: rgba(197, 199, 194, 0.3); margin: 1rem 0;"></div>
              <p class="font-sans mb-0" style="font-size: 0.75rem; color: #8c8c88;">Lifetime spending</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Back to Rooms Button -->
    <div class="text-center mt-5">
      <a href="/rooms" class="btn btn-luxury-primary btn-lg px-5">
        <i class="bi bi-arrow-left"></i> Back to Rooms
      </a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
