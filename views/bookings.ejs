<%- include('partials/header') %>

<main class="luxury-main">
  <div class="container-fluid py-5 px-4 px-xl-5">
    <!-- Header Section -->
    <header class="mb-5">
      <span class="text-uppercase font-sans fw-bold subheading">Your Reservations</span>
      <h1 class="font-serif fw-bold mt-3 mb-3 text-primary-luxury heading-room">My Bookings</h1>
      <p class="text-muted-luxury font-sans">Track and manage all your room bookings in one place</p>
    </header>

    <!-- Bookings List -->
    <% if (bookings.length === 0) { %>
      <div class="p-5 text-center stat-card">
        <i class="bi bi-calendar-x text-muted-luxury fs-3-rem"></i>
        <h3 class="font-serif mt-4 text-primary-luxury">No Bookings Yet</h3>
        <p class="font-sans mt-2 text-muted-luxury">
          Browse our rooms and make your first reservation!
        </p>
        <a href="/rooms" class="btn btn-luxury-primary mt-3">
          <i class="bi bi-building"></i> Browse Rooms
        </a>
      </div>
    <% } else { %>
    <div class="row g-4 mb-5">
      <!-- Bookings Table -->
      <div class="col-12">
        <div class="table-responsive">
          <table class="table table-borderless w-100 mb-0 admin-table-spaced">
            <thead>
              <tr>
                <th class="admin-table-header">Room</th>
                <th class="admin-table-header">Guest</th>
                <th class="admin-table-header">Check-In</th>
                <th class="admin-table-header">Check-Out</th>
                <th class="admin-table-header">Status</th>
                <th class="admin-table-header text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% bookings.forEach(booking => { %>
              <tr class="luxury-card-static">
                <td class="admin-table-cell">
                  <div class="font-serif fw-bold text-primary-luxury mb-1"><%= booking.room ? booking.room.name : 'Deleted Room' %></div>
                  <small class="text-muted-luxury">₹<%= booking.monthlyRate %>/month</small>
                </td>
                <td class="admin-table-cell">
                  <div class="font-serif fw-bold text-primary-luxury"><%= booking.guestName %></div>
                  <small class="text-muted-luxury"><%= booking.email %></small>
                </td>
                <td class="admin-table-cell">
                  <div class="text-muted-luxury"><%= new Date(booking.checkIn).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) %></div>
                </td>
                <td class="admin-table-cell">
                  <div class="text-muted-luxury"><%= booking.checkOut ? new Date(booking.checkOut).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) : 'Not set' %></div>
                </td>
                <td class="admin-table-cell">
                  <% if (booking.status === 'Confirmed') { %>
                    <span class="badge badge-confirmed">
                      <i class="bi bi-check-circle-fill icon-sm"></i> Confirmed
                    </span>
                  <% } else if (booking.status === 'Cancelled') { %>
                    <span class="badge badge-cancelled">
                      <i class="bi bi-x-circle-fill icon-sm"></i> Cancelled
                    </span>
                  <% } else { %>
                    <span class="badge badge-pending">
                      <i class="bi bi-clock-fill icon-sm"></i> Pending
                    </span>
                  <% } %>
                </td>
                <td class="admin-table-cell text-end">
                  <a href="/confirmation/<%= booking._id %>" class="btn btn-luxury-primary btn-sm">
                    <i class="bi bi-eye"></i> View Details
                  </a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
    <% } %>

    <!-- Back to Rooms Button -->
    <div class="text-center mt-5">
      <a href="/rooms" class="btn btn-luxury-primary btn-lg px-5">
        <i class="bi bi-arrow-left"></i> Back to Rooms
      </a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
