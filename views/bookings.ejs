<%- include('partials/header') %>

<main class="luxury-main">
  <div class="container-fluid py-5 px-4 px-xl-5">
    <!-- Header Section -->
    <header class="mb-5">
      <span class="text-uppercase font-sans fw-bold subheading">Your Reservations</span>
      <h1 class="font-serif fw-bold mt-3 mb-3 text-primary-luxury heading-room">My Bookings</h1>
      <p class="text-muted-luxury font-sans">Track and manage all your room bookings in one place</p>
    </header>

    <!-- Bookings List -->
    <% if (bookings.length === 0) { %>
      <div class="p-5 text-center stat-card">
        <i class="bi bi-calendar-x text-muted-luxury fs-3-rem"></i>
        <h3 class="font-serif mt-4 text-primary-luxury">No Bookings Yet</h3>
        <p class="font-sans mt-2 text-muted-luxury">
          Browse our rooms and make your first reservation!
        </p>
        <a href="/rooms" class="btn btn-luxury-primary mt-3">
          <i class="bi bi-building"></i> Browse Rooms
        </a>
      </div>
    <% } else { %>
    <div class="row g-4 mb-5">
      <!-- Bookings Table -->
      <div class="col-12">
        <div class="table-responsive">
          <table class="table table-borderless table-luxury w-100 mb-0">
            <thead>
              <tr>
                <th>Room Name</th>
                <th>Guest Name</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Duration</th>
                <th>Status</th>
                <th class="text-end">Action</th>
              </tr>
            </thead>
            <tbody>
              <% bookings.forEach(booking => { %>
              <tr>
                <td>
                  <div class="font-serif fw-bold text-primary-luxury fs-4"><%= booking.room ? booking.room.name : 'Unknown Room' %></div>
                  <div class="text-muted-luxury mt-1 subheading-light">Room</div>
                </td>
                <td class="text-primary-luxury font-sans"><%= booking.guestName %></td>
                <td class="text-muted-luxury font-sans"><%= new Date(booking.checkIn).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
                <td class="text-muted-luxury font-sans"><%= new Date(booking.checkOut).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
                <td class="text-muted-luxury font-sans">
                  <% const months = booking.months || 1; %>
                  <%= months %> <%= months === 1 ? 'month' : 'months' %>
                </td>
                <td>
                  <span class="badge badge-luxury badge-confirmed">
                    <i class="bi bi-check-circle-fill"></i> Confirmed
                  </span>
                </td>
                <td class="text-end">
                  <a href="/confirmation/<%= booking._id %>" class="btn btn-luxury-primary btn-view-sm">
                    <i class="bi bi-eye"></i> View
                  </a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Booking Stats -->
      <div class="col-12 mt-5">
        <div class="row g-4">
          <div class="col-md-4">
            <div class="stat-card">
              <div class="stat-label">Total Bookings</div>
              <div class="stat-value"><%= bookings.length %></div>
              <div class="stat-divider"></div>
              <p class="font-sans mb-0 text-small-muted">All time reservations</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="stat-card">
              <div class="stat-label">Active Bookings</div>
              <div class="stat-value"><%= bookings.filter(b => new Date(b.checkOut) > new Date()).length %></div>
              <div class="stat-divider"></div>
              <p class="font-sans mb-0 text-small-muted">Currently active stays</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="stat-card">
              <div class="stat-label">Total Spent</div>
              <div class="stat-value">₹<%= bookings.reduce((sum, b) => sum + (b.room ? b.room.monthlyPrice * (b.months || 1) : 0), 0) %></div>
              <div class="stat-divider"></div>
              <p class="font-sans mb-0 text-small-muted">Lifetime spending</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Back to Rooms Button -->
    <div class="text-center mt-5">
      <a href="/rooms" class="btn btn-luxury-primary btn-lg px-5">
        <i class="bi bi-arrow-left"></i> Back to Rooms
      </a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
