<%- include('partials/header') %>

<main class="luxury-main">
  <div class="container-fluid py-5 px-4 px-xl-5">
    <div class="row justify-content-center">
      <div class="col-lg-7">
        
        <!-- Success Header -->
        <div class="text-center mb-5">
          <div class="mb-4 confirmation-success-icon">
            <i class="bi bi-check-lg"></i>
          </div>
          <h1 class="font-serif fw-bold mt-4 confirmation-heading">Booking Confirmed!</h1>
          <p class="font-sans mt-3 text-muted-luxury fs-1">Your reservation has been placed successfully.</p>
        </div>
        
        <!-- Booking Details Card -->
        <div class="luxury-card-static mb-4">
          <div class="p-4 border-bottom">
            <span class="font-sans subheading">Reservation Details</span>
          </div>
          <div class="table-responsive">
            <table class="confirmation-table">
              <tr>
                <th>Booking ID</th>
                <td><code><%= booking._id %></code></td>
              </tr>
              <tr>
                <th>Guest Name</th>
                <td class="font-serif fw-bold"><%= booking.guestName %></td>
              </tr>
              <tr>
                <th>Room</th>
                <td><%= booking.room.name %> <span class="badge badge-luxury badge-pending ms-2"><%= booking.room.type %></span></td>
              </tr>
              <tr>
                <th>Move-In Date</th>
                <td><%= new Date(booking.checkIn).toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %></td>
              </tr>
              <tr>
                <th>Move-Out Date</th>
                <td><%= new Date(booking.checkOut).toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %></td>
              </tr>
              <tr>
                <th>Guests</th>
                <td><%= booking.guests %> person(s)</td>
              </tr>
              <tr>
                <th>Duration</th>
                <td><%= booking.months %> month(s)</td>
              </tr>
              <tr>
                <th>Monthly Rate</th>
                <td>₹<%= booking.monthlyRate %>/month</td>
              </tr>
              <tr>
                <th>Total Rent</th>
                <td><span class="font-serif fw-bold text-secondary-luxury price-value-large">₹<%= booking.totalPrice %></span></td>
              </tr>
              <tr>
                <th>Status</th>
                <td><span class="badge badge-luxury badge-confirmed"><i class="bi bi-check-circle-fill"></i> <%= booking.status %></span></td>
              </tr>
            </table>
          </div>
        </div>

        <!-- Utilities Information -->
        <% if (booking.utilities) { %>
        <div class="luxury-card-static mb-4">
          <div class="p-4 border-bottom">
            <span class="font-sans subheading">
              <i class="bi bi-lightning-charge-fill"></i> Utilities Billing
            </span>
          </div>
          <div class="p-4">
            <div class="row g-4">
              <div class="col-md-6">
                <p class="font-sans mb-1 subheading-light">Electricity</p>
                <span class="badge badge-luxury badge-pending"><%= booking.utilities.electricity %></span>
              </div>
              <div class="col-md-6">
                <p class="font-sans mb-1 subheading-light">Water</p>
                <span class="badge badge-luxury badge-pending"><%= booking.utilities.water %></span>
              </div>
            </div>
            <p class="font-sans mt-3 mb-0 text-muted-luxury fs-085">Note: <%= booking.utilities.description %></p>
          </div>
        </div>
        <% } %>

        <!-- Action Buttons -->
        <div class="d-flex gap-3 justify-content-center mt-5">
          <a href="/bookings" class="btn btn-luxury-primary">
            <i class="bi bi-list-check"></i> View All Bookings
          </a>
          <a href="/rooms" class="btn btn-luxury-outline">
            <i class="bi bi-house"></i> Browse More Rooms
          </a>
        </div>
        
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
