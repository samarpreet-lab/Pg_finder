<%- include('partials/header') %>

<main class="luxury-main">
  <!-- Hero Section -->
  <section class="section-hero">
    <div class="container-fluid px-4 px-xl-5">
      <div class="text-center mb-5">
        <h1 class="font-serif heading-hero">Find Your Perfect PG 🏠</h1>
        <p class="font-sans text-hero-description">Browse affordable PG rooms across Punjab, check availability, and book your stay instantly.</p>
      </div>

      <!-- Search Bar -->
      <form action="/rooms" method="GET" class="row g-3 justify-content-center align-items-end">
        <div class="col-auto">
          <select name="type" class="form-select font-sans filter-input">
            <option value="">All Room Types</option>
            <option value="Single">Single Occupancy</option>
            <option value="Double">Double Sharing</option>
            <option value="Suite">Triple/Family</option>
            <option value="Deluxe">Shared / Family</option>
          </select>
        </div>
        <div class="col-auto">
          <input type="number" name="maxPrice" class="form-control font-sans filter-input" 
                 placeholder="Max Monthly Price (₹)" min="0"/>
        </div>
        <div class="col-auto">
          <button type="submit" class="btn font-sans btn-search">
            <i class="bi bi-search"></i> Search
          </button>
        </div>
      </form>
    </div>
  </section>

<!-- Stats Section -->
<section class="section-stats">
  <div class="container-fluid px-4 px-xl-5">
    <div class="row text-center g-5">
      <div class="col-md-4">
        <div class="stat-label font-sans">Total Rooms</div>
        <h2 class="font-serif stat-value-medium">50+</h2>
        <div class="stat-divider"></div>
        <p class="font-sans text-small-muted">Rooms Available</p>
      </div>
      <div class="col-md-4">
        <div class="stat-label font-sans">Happy Residents</div>
        <h2 class="font-serif stat-value-medium">1000+</h2>
        <div class="stat-divider"></div>
        <p class="font-sans text-small-muted">Satisfied Customers</p>
      </div>
      <div class="col-md-4">
        <div class="stat-label font-sans">Average Rating</div>
        <h2 class="font-serif stat-value-medium">4.8 ⭐</h2>
        <div class="stat-divider"></div>
        <p class="font-sans text-small-muted">Customer Rating</p>
      </div>
    </div>
  </div>
</section>


<!-- Featured Rooms -->
<section class="section-featured">
  <div class="container-fluid px-4 px-xl-5">
    <div class="mb-5">
      <span class="text-uppercase font-sans subheading">Discover</span>
      <h2 class="font-serif heading-section">Featured Affordable Rooms</h2>
    </div>
    <div class="row g-4">
      <% rooms.slice(0, 3).forEach(room => { %>
      <div class="col-md-4">
        <div class="luxury-card">
          <div class="room-card-image-container">
            <img src="<%= room.image %>" alt="<%= room.name %>" class="room-card-image"/>
            <span class="font-sans room-card-badge-type">
              <%= room.type === 'Single' ? 'Single Occupancy' : room.type === 'Double' ? 'Double Sharing' : 'Family/Suite' %>
            </span>
            <span class="font-serif room-card-badge-price">
              ₹<%= room.monthlyPrice %><span class="price-suffix">/mo</span>
            </span>
          </div>
          <div class="room-card-body">
            <h5 class="font-serif room-card-title"><%= room.name %></h5>
            <p class="font-sans text-description"><%= room.description.substring(0, 80) %>...</p>
            <div class="room-card-footer">
              <span class="font-sans text-small-muted"><i class="bi bi-star-fill text-warning"></i> <%= room.rating %> rating</span>
              <a href="/rooms/<%= room._id %>" class="font-sans room-card-link">
                View Details
              </a>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <div class="text-center mt-5">
      <a href="/rooms" class="btn btn-luxury-primary font-sans">
        Browse All Rooms →
      </a>
    </div>
  </div>
</section>


<!-- Why Choose Us -->
<section class="section-why">
  <div class="container-fluid px-4 px-xl-5">
    <div class="text-center mb-5">
      <span class="text-uppercase font-sans subheading">Why Choose Us</span>
      <h2 class="font-serif heading-section">StayEase PG for Students & Workers</h2>
    </div>
    <div class="row g-5">
      <div class="col-md-3 text-center">
        <i class="bi bi-shield-check icon-feature"></i>
        <h5 class="font-sans text-feature-title">Verified Homes</h5>
        <div class="icon-divider"></div>
        <p class="font-sans text-description">Homes vetted for students and working professionals across Punjab.</p>
      </div>
      <div class="col-md-3 text-center">
        <i class="bi bi-clock icon-feature"></i>
        <h5 class="font-sans text-feature-title">Instant Booking</h5>
        <div class="icon-divider"></div>
        <p class="font-sans text-description">Book in seconds with instant confirmation.</p>
      </div>
      <div class="col-md-3 text-center">
        <i class="bi bi-cash-coin icon-feature"></i>
        <h5 class="font-sans text-feature-title">Affordable Rent</h5>
        <div class="icon-divider"></div>
        <p class="font-sans text-description">Budget-friendly monthly rooms for students and shared households.</p>
      </div>
      <div class="col-md-3 text-center">
        <i class="bi bi-headset icon-feature"></i>
        <h5 class="font-sans text-feature-title">24/7 Support</h5>
        <div class="icon-divider"></div>
        <p class="font-sans text-description">Round the clock customer support.</p>
      </div>
    </div>
  </div>
</section>

</main>

<%- include('partials/footer') %>
