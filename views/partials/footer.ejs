<% if (typeof isAuthPage === 'undefined' || !isAuthPage) { %>
  <!-- Luxury Footer -->
  <footer class="luxury-footer">
    <div class="px-4 px-xl-5 py-5">
      <div class="row g-4">
        <!-- Brand Column -->
        <div class="col-md-4">
          <h5 class="font-serif footer-brand">StayEase</h5>
          <p class="font-sans footer-tagline">Affordable Living</p>
          <p class="font-sans footer-description">
            Premium shared accommodations and PG stays for students, workers, and professionals across Punjab.
          </p>
        </div>
        
        <!-- Quick Links -->
        <div class="col-md-2">
          <h6 class="font-sans footer-heading">Explore</h6>
          <ul class="list-unstyled">
            <li class="mb-2"><a href="/" class="font-sans footer-link">Home</a></li>
            <li class="mb-2"><a href="/rooms" class="font-sans footer-link">Browse Rooms</a></li>
            <li class="mb-2"><a href="/bookings" class="font-sans footer-link">My Bookings</a></li>
          </ul>
        </div>
        
        <!-- Support -->
