          Crafted with <i class="bi bi-heart-fill footer-contact-icon"></i> for affordable living
        </p>
      </div>
    </div>
  </footer>
<% } %>

<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
