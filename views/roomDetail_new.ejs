<%- include('partials/header') %>

<main class="luxury-main">
  <div class="container-fluid py-5 px-4 px-xl-5">
    <div class="row g-5">

      <!-- Room Image -->
      <div class="col-md-7">
        <div class="room-detail-image-wrapper">
          <img src="<%= room.image %>" class="w-100 room-detail-image" alt="<%= room.name %>"/>
        </div>
      </div>

      <!-- Room Info -->
      <div class="col-md-5">
        <span class="badge-luxury font-sans mb-3 d-inline-block">
          <%= room.type === 'Single' ? 'Single Occupancy' : room.type === 'Double' ? 'Double Sharing' : room.type === 'Suite' ? 'Triple / Family' : 'Shared / Family' %>
        </span>
        
        <h1 class="font-serif fw-bold mb-3 heading-room-detail"><%= room.name %></h1>
        
        <div class="mb-3">
          <% for(let i = 0; i < Math.floor(room.rating); i++) { %>
            <i class="bi bi-star-fill star-rating"></i>
          <% } %>
          <span class="font-sans ms-2 rating-text">(<%= room.rating %>)</span>
        </div>
        
        <p class="font-sans mb-4 description-text"><%= room.description %></p>

        <!-- Price -->
        <div class="mb-4 p-4 price-box-dark">
          <div class="stat-label font-sans price-box-label-light">Monthly Rate</div>
          <span class="font-serif fw-bold price-box-value-large">₹<%= room.monthlyPrice %></span>
          <span class="font-sans price-box-period"> / month</span>
        </div>

        <!-- Utilities Information -->
        <% if (room.utilities) { %>
        <div class="mb-4 p-4 utilities-box">
          <h6 class="font-sans fw-bold mb-3 utilities-title">
            <i class="bi bi-lightning-charge-fill"></i> Utilities
          </h6>
          <p class="mb-2 font-sans utilities-text">
            <strong>Electricity:</strong> <span class="badge badge-utilities"><%= room.utilities.electricity %></span>
          </p>
          <p class="mb-0 font-sans utilities-text">
            <strong>Water:</strong> <span class="badge badge-utilities"><%= room.utilities.water %></span>
          </p>
        </div>
        <% } %>

        <!-- Amenities -->
        <div class="mb-4">
          <h6 class="font-sans fw-bold mb-3 amenities-title">Amenities</h6>
          <div class="d-flex flex-wrap gap-2">
            <% room.amenities.forEach(a => { %>
              <span class="badge font-sans badge-amenity">
                <i class="bi bi-check-circle-fill amenity-check"></i> <%= a %>
              </span>
            <% }) %>
          </div>
        </div>

        <!-- Availability -->
        <% if (room.isAvailable) { %>
          <div class="mb-3 p-3 availability-available">
            <span class="font-sans availability-text">
              <i class="bi bi-check-circle-fill"></i> Room is Available
            </span>
          </div>
          <a href="/book/<%= room._id %>" class="btn btn-luxury-primary w-100 mb-3 font-sans">
            <i class="bi bi-calendar-check"></i> Book Now
          </a>
        <% } else { %>
          <div class="mb-3 p-3 availability-unavailable">
            <span class="font-sans availability-text-unavailable">
              <i class="bi bi-x-circle-fill"></i> Currently Unavailable
            </span>
          </div>
        <% } %>

        <a href="/rooms" class="btn btn-luxury-outline w-100 font-sans">
          <i class="bi bi-arrow-left"></i> Back to Rooms
        </a>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
