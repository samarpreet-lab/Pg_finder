<%- include('partials/header') %>

<main class="luxury-main">
  <div class="container-fluid py-5 px-4 px-xl-5">
    <!-- Header Section -->
    <header class="mb-5">
      <span class="text-uppercase font-sans fw-bold subheading">Discover Your Stay</span>
      <h1 class="font-serif heading-page">Browse Accommodations</h1>
    </header>

    <!-- Filter & Search Bar -->
    <section class="mb-5">
      <div class="card shadow-sm filter-card">
        <div class="card-body p-0">
          <form action="/rooms" method="GET" class="d-flex flex-wrap align-items-center">
            <!-- Search Input -->
            <div class="flex-grow-1 px-4 py-3 d-flex align-items-center border-end filter-section">
              <i class="bi bi-search font-sans filter-icon"></i>
              <input 
                type="text" 
                name="search"
                placeholder="Search by room name or description..." 
                value="<%= query.search || '' %>"
                class="form-control border-0 ms-3 ps-0 font-sans"
              />
            </div>

            <!-- Room Type Dropdown -->
            <div class="px-4 py-3 border-end d-flex align-items-center filter-section">
              <label class="me-3 text-uppercase font-sans fw-bold filter-label">Room Type</label>
              <select name="type" class="form-select form-select-sm border-0 font-sans">
                <option value="" <%= !query.type ? 'selected' : '' %>>All</option>
                <option value="Single" <%= query.type === 'Single' ? 'selected' : '' %>>Single</option>
                <option value="Double" <%= query.type === 'Double' ? 'selected' : '' %>>Double</option>
                <option value="Suite" <%= query.type === 'Suite' ? 'selected' : '' %>>Suite</option>
                <option value="Deluxe" <%= query.type === 'Deluxe' ? 'selected' : '' %>>Deluxe</option>
              </select>
            </div>

            <!-- Price Range -->
            <div class="px-4 py-3 border-end d-flex align-items-center filter-section">
              <label class="me-3 text-uppercase font-sans fw-bold filter-label">Max Price</label>
              <input 
                type="number" 
                name="maxPrice" 
                min="0" 
                placeholder="₹ Max" 
                value="<%= query.maxPrice || '' %>"
                class="form-control form-control-sm border-0 font-sans"
              />
            </div>

            <!-- Apply Filters Button -->
            <button type="submit" class="btn btn-luxury-primary px-5 py-3 m-0 font-sans">
              Apply Filters
            </button>
          </form>
        </div>
      </div>
    </section>

    <!-- Room Cards Grid -->
    <% if (rooms.length === 0) { %>
      <div class="alert text-center py-5 alert-no-results">
        <i class="bi bi-exclamation-triangle fs-2-rem"></i>
        <p class="mt-3 mb-0 font-sans fs-1-1">No rooms found matching your criteria. Try adjusting your filters.</p>
      </div>
    <% } else { %>
    <section class="room-cards-grid">
      <div class="row g-4">
        <% rooms.forEach(room => { %>
        <!-- Room Card -->
        <div class="col-md-6 col-lg-4">
          <div class="luxury-card h-100">
            
            <!-- Image Container with Badges -->
            <div class="position-relative overflow-hidden card-img-height-300">
              <img src="<%= room.image %>" class="w-100 h-100 rooms-list-card-image" alt="<%= room.name %>"/>
              
              <!-- Room Type Badge (Top-Left) -->
              <span class="position-absolute top-0 start-0 m-3 px-3 py-2 fw-bold text-uppercase font-sans room-card-badge-type">
                <%= room.type === 'Single' ? 'Single' : room.type === 'Double' ? 'Double' : room.type === 'Suite' ? 'Family' : 'Shared' %>
              </span>

              <!-- Price Badge (Top-Right) -->
              <span class="position-absolute top-0 end-0 m-3 px-3 py-2 fw-bold text-white text-uppercase font-serif room-card-badge-price">
                ₹<%= room.monthlyPrice %><span class="price-suffix">/month</span>
              </span>
            </div>

            <!-- Card Body -->
            <div class="card-body d-flex flex-column room-card-body">
              <h5 class="card-title fw-bold mb-2 font-serif room-card-title">
                <%= room.name %>
              </h5>

              <!-- Location -->
              <p class="text-secondary small mb-3 d-flex align-items-center font-sans text-secondary-luxury">
                <i class="bi bi-geo-alt-fill me-2"></i> Heritage Block, Sector 4
              </p>

              <!-- Description -->
              <p class="text-muted small mb-3 font-sans text-muted-luxury">
                <%= room.description.substring(0, 100) %>...
              </p>

              <!-- Amenities -->
              <div class="d-flex flex-wrap gap-2 mb-4">
                <% room.amenities.slice(0, 3).forEach(amenity => { %>
                  <span class="badge rounded-pill font-sans amenity-badge-simple">
                    <%= amenity %>
                  </span>
                <% }) %>
              </div>

              <!-- Footer with Rating & CTA -->
              <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top room-card-footer">
                <span class="small font-sans text-small-muted">
                  <i class="bi bi-star-fill text-warning"></i> <%= room.rating %> rating
                </span>
                <a href="/rooms/<%= room._id %>" class="btn btn-outline-dark btn-sm px-4 fw-semibold font-sans btn-luxury-outline">
                  View
                </a>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </section>
    <% } %>

    <!-- Load More Section -->
    <div class="text-center py-5 mt-5">
      <div class="mb-4 icon-divider"></div>
      <button class="btn btn-link text-decoration-none font-sans text-primary-luxury fw-bold text-uppercase letter-spacing-1 fs-075">
        <i class="bi bi-arrow-down"></i> Load More Collections
      </button>
    </div>
  </div>
</main>

<%- include('partials/footer') %>